MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=Exness-MT5Trial
MT5_TERMINAL_PATH=C:\MT5_scalper\terminal64.exe

SYMBOL=XAUUSDm
LOT_SIZE=0.2
RUNAWAY_MAX_OPEN=50
SCAN_INTERVAL_SECONDS=5

# Risk / management: XAUUSDm point=0.001 and 1 pip=0.01.
# TP1 is fixed to 1 executed R (20 pips); the ordinary runner is 2R.
SL_CAP_PIPS=20
TP_FINAL_R=2.0
PARTIAL_CLOSE_PCT=50
TRADE_MAX_AGE_MINUTES=60
BE_COST_BUFFER_PIPS=8.0
TRAIL_MODE=structure
ATR_MULT=1.5
TRAIL_ATR_PERIOD=14
TRAIL_SWING_LOOKBACK=2
TRAIL_BUFFER_PIPS=2.0
PIP_VALUE_PER_LOT_USD=1.0
COOLDOWN_MINUTES=10
PENDING_ORDER_EXPIRY_MIN=15
MAX_SPREAD_PIPS=4.0

# SPEC D starting hypotheses
S1_EQUAL_LEVEL_TOLERANCE_PIPS=1.5
S1_SWEEP_LOOKBACK_BARS=20
S1_REQUIRE_CHOCH=false
S1_SL_BUFFER_PIPS=2.0
S1_COOLDOWN_SECONDS=0
S2_COMPRESSION_BARS=10
S2_MAX_RANGE_PIPS=15
S2_DISPLACEMENT_BODY_RATIO=1.5
S2_SL_BUFFER_PIPS=2.0
S3_EMA_PERIOD=20
S3_EXTENSION_PIPS=25
S3_WICK_REJECTION_RATIO=0.6
S3_SL_BUFFER_PIPS=2.0
S4_TREND_EMA=50
S4_BOS_LOOKBACK_BARS=30
S4_REQUIRE_FVG_OR_OB=false
S4_SL_BUFFER_PIPS=2.0
S4_PULLBACK_TOLERANCE_PIPS=5.0

# News tagging (non-blocking)
FINNHUB_API_KEY=your_finnhub_key

TIMEZONE=Africa/Casablanca
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=4
MT5_CONNECT_RETRIES=5
MT5_RETRY_BASE_SECONDS=2
MT5_RETRY_MAX_SECONDS=30
DASHBOARD_PORT=8080
EXCEL_EXPORT_PATH=data\scalper_journal.xlsx
